---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout title="Projects" description="Things I've built or am tinkering with.">
  <header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Projects</h1>
    <p class="mt-2 text-zinc-600 dark:text-zinc-400">Things I've built or am currently tinkering with.</p>
  </header>

  {projects.length === 0 ? (
    <p class="text-zinc-500">Projects coming soon.</p>
  ) : (
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  )}
</BaseLayout>
