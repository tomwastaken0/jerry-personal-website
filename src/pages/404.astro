---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <div class="py-24 text-center">
    <p class="text-6xl">🐼</p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight">404 — page not found</h1>
    <p class="mt-2 text-zinc-600 dark:text-zinc-400">That page wandered off. Let's get you back.</p>
    <a href="/" class="mt-6 inline-block rounded-lg bg-accent-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-accent-700">Back home</a>
  </div>
</BaseLayout>
