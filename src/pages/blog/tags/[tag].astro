---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`Posts tagged #${tag}`}>
  <header class="mb-8">
    <a href="/blog" class="text-sm text-zinc-500 hover:text-accent-600 dark:hover:text-accent-400">← All posts</a>
    <h1 class="mt-2 text-3xl font-bold tracking-tight">Posts tagged <span class="text-accent-600 dark:text-accent-400">#{tag}</span></h1>
  </header>
  <div class="grid gap-6 sm:grid-cols-2">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>
