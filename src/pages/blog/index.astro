---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Collect unique tags for the filter row.
const tags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="Blog" description="Notes on engineering, tech, and whatever I'm learning.">
  <header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Blog</h1>
    <p class="mt-2 text-zinc-600 dark:text-zinc-400">Notes on engineering, tech, and whatever I'm learning.</p>
    {tags.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <li>
            <a href={`/blog/tags/${tag}/`} class="rounded-full border border-zinc-200 px-3 py-1 text-xs font-medium text-zinc-600 hover:border-accent-500 hover:text-accent-600 dark:border-zinc-700 dark:text-zinc-400 dark:hover:text-accent-400">#{tag}</a>
          </li>
        ))}
      </ul>
    )}
  </header>

  {posts.length === 0 ? (
    <p class="text-zinc-500">No posts yet — check back soon.</p>
  ) : (
    <div class="grid gap-6 sm:grid-cols-2">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  )}
</BaseLayout>
