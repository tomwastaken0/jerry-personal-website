---
import { NAV, SITE } from '../site';
import ThemeToggle from './ThemeToggle.astro';

// Highlight the current section.
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-zinc-200/70 bg-white/80 backdrop-blur dark:border-zinc-800/70 dark:bg-zinc-950/80">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/" class="flex items-center gap-2 text-lg font-semibold tracking-tight">
      <span aria-hidden="true">🐼</span>
      <span>{SITE.name}</span>
    </a>

    <div class="flex items-center gap-1">
      <ul class="hidden items-center gap-1 md:flex">
        {NAV.filter((i) => i.href !== '/').map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'rounded-lg px-3 py-2 text-sm font-medium transition',
                isActive(item.href)
                  ? 'text-accent-600 dark:text-accent-400'
                  : 'text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-white',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <ThemeToggle />

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        type="button"
        aria-label="Open menu"
        class="rounded-lg p-2 text-zinc-600 hover:bg-zinc-100 md:hidden dark:text-zinc-300 dark:hover:bg-zinc-800"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <ul id="mobile-menu" class="hidden border-t border-zinc-200 px-4 py-2 md:hidden dark:border-zinc-800">
    {NAV.filter((i) => i.href !== '/').map((item) => (
      <li>
        <a href={item.href} class="block rounded-lg px-3 py-2 text-sm font-medium text-zinc-700 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800">
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</header>

<script is:inline>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
